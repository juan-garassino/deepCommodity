# deepCommodity local environment.
#
# Usage:
#   cp .env.sample .env
#   chmod 600 .env
#   $EDITOR .env       # fill in the values
#
# .env is gitignored — never commit it.
#
# When you're done testing locally, paste the SAME key=value pairs into the
# "Environment variables" field of your Claude Code cloud environment at
# claude.ai/code/routines (see .claude/routines/managed/REGISTER.md).
# The schema is identical between local and managed.

# =============================================================================
# Trading mode (THE big switch)
# =============================================================================
# paper = no real money on either broker (testnet/paper endpoints).
# live  = real money. Also requires DAILY_DECISION_AUTHORIZE_LIVE=true AND
#         BINANCE_TESTNET=false / ALPACA_PAPER=false on the relevant broker.
TRADING_MODE=paper
DAILY_DECISION_AUTHORIZE_LIVE=false

# =============================================================================
# Crypto — Binance (default venue) and Bitfinex (alternative)
# =============================================================================
BROKER_CRYPTO=binance              # binance | bitfinex

BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true               # set to false for live trading

BITFINEX_API_KEY=
BITFINEX_API_SECRET=
BITFINEX_PAPER=true

# =============================================================================
# US equities — Alpaca
# =============================================================================
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER=true                  # set to false for live trading

# =============================================================================
# News
# =============================================================================
# OpenAI's web-search-enabled chat completion (preferred — no deposit minimum).
# Auto-used when set. Costs ~$0.04 per call (gpt-4o-mini-search-preview).
OPENAI_API_KEY=

# Optional fallback (Perplexity tier 0 requires a $50 deposit, hence not default).
# PERPLEXITY_API_KEY=

# =============================================================================
# Macro & market data (optional)
# =============================================================================
COINGECKO_API_KEY=                 # optional, raises CoinGecko rate limits
FRED_API_KEY=                      # for tools/fetch_macro.py + tools/fetch_fedwatch.py
ALPHAVANTAGE_API_KEY=              # optional, news + sentiment

# Equity catalysts
FINNHUB_API_KEY=                   # https://finnhub.io/register — earnings calendar (free, 60/min)

# On-chain crypto
CRYPTOQUANT_API_KEY=               # https://cryptoquant.com/auth — exchange reserves (free, limited)
GLASSNODE_API_KEY=                 # https://studio.glassnode.com/settings/api — NUPL, MVRV (free tier)
SANTIMENT_API_KEY=                 # https://app.santiment.net/account/api-keys — social, dev (free)

# =============================================================================
# Telegram — status / alert pings
# =============================================================================
# 1. DM @BotFather on Telegram, run /newbot, save the token.
# 2. DM your new bot once.
# 3. Visit https://api.telegram.org/bot<TOKEN>/getUpdates and copy from.id.
# Both must be set; leaving them empty silently disables Telegram pings (the
# routines never fail when Telegram is down).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# =============================================================================
# Git author for log-branch commits (managed routines + VPS deploy)
# =============================================================================
# When persist_logs.sh commits RESEARCH-LOG / TRADE-LOG / WEEKLY-REVIEW
# updates back to the claude/logs branch, this is the author identity.
GIT_BOT_EMAIL=bot@deepcommodity.local
GIT_BOT_NAME=deepCommodity-bot

# =============================================================================
# Sentiment backend (optional)
# =============================================================================
# rule-based (default) | sklearn | huggingface
# rule-based works with no extra deps. Switch to sklearn after you've
# accumulated labeled news+outcome data; huggingface requires `transformers`.
# SENTIMENT_BACKEND=rule-based
# SENTIMENT_MODEL_PATH=
